# 复制为 .env 并填入真实凭据:
# cp .env.example .env
# 然后 python -m app.cli run --industry ... --competitors ... 即可

# Doubao (火山方舟 ARK)
DOUBAO_API_KEY=ark-xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxx
DOUBAO_ENDPOINT=ep-xxxxxxxxxx-xxxxxx

# Langfuse (可选, 不配则跳过)
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com